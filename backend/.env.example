APP_NAME=Forest Analytics API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://<username>:<password>@<host>:5432/<database>
STRICT_PROD_MODE=true
DEMO_CACHE_ENABLED=false
LOG_LEVEL=INFO

GEE_PROJECT=
GEE_SERVICE_ACCOUNT=
GEE_PRIVATE_KEY_FILE=
RAW_DATA_DIR=

INGESTION_START_DATE=
INGESTION_END_DATE=
INGESTION_LOOKBACK_MONTHS=6
INGESTION_REGION_BBOX=73.55,20.05,74.25,21.10
INGESTION_REGION_GEOJSON=
INGESTION_MAX_CLOUD_PCT=20
INGESTION_SCALE_METERS=10
INGESTION_BANDS=B2,B4,B8,B11
INGESTION_OUTPUT_NAME=sentinel2_composite.tif
INGESTION_S1_OUTPUT_NAME=sentinel1_composite.tif
INGESTION_S1_POLARIZATIONS=VV,VH
INGESTION_S1_INSTRUMENT_MODE=IW
INGESTION_S1_ORBIT_PASS=ANY
INGESTION_INTERACTIVE_AUTH=false

PROCESSED_DATA_DIR=
PROCESSING_INPUT_NAME=sentinel2_composite.tif
PROCESSING_NDVI_NAME=ndvi.tif
PROCESSING_NDMI_NAME=ndmi.tif
PROCESSING_EVI_NAME=evi.tif
PROCESSING_BLUE_BAND_INDEX=1
PROCESSING_RED_BAND_INDEX=2
PROCESSING_NIR_BAND_INDEX=3
PROCESSING_SWIR_BAND_INDEX=4
PROCESSING_S1_INPUT_NAME=sentinel1_composite.tif
PROCESSING_VV_NAME=vv.tif
PROCESSING_VH_NAME=vh.tif
PROCESSING_VV_VH_RATIO_NAME=vv_vh_ratio.tif
PROCESSING_VV_BAND_INDEX=1
PROCESSING_VH_BAND_INDEX=2
PROCESSING_CLIP_MIN=-1.0
PROCESSING_CLIP_MAX=1.0

FEATURES_OUTPUT_CSV=features.csv
FEATURES_SOURCE_NAME=sentinel2
FEATURES_TIMESTAMP_UTC=
FEATURES_WRITE_TO_DB=true
FEATURES_SKIP_NODATA=true
FEATURES_GRID_PREFIX=cell
PROCESSING_NDVI_BASELINE_NAME=

REGION_PIPELINE_ENABLED=true
REGION_PIPELINE_MIN_INTERVAL_SEC=300
REGION_PIPELINE_TRIGGER_ON_REQUEST=true
