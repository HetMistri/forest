APP_NAME=Forest Analytics API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://<username>:<password>@<host>:5432/<database>
DEMO_CACHE_ENABLED=true

GEE_PROJECT=
GEE_SERVICE_ACCOUNT=
GEE_PRIVATE_KEY_FILE=
RAW_DATA_DIR=

INGESTION_START_DATE=
INGESTION_END_DATE=
INGESTION_LOOKBACK_MONTHS=6
INGESTION_REGION_BBOX=73.55,20.05,74.25,21.10
INGESTION_REGION_GEOJSON=
INGESTION_MAX_CLOUD_PCT=20
INGESTION_SCALE_METERS=10
INGESTION_BANDS=B4,B8,B11
INGESTION_OUTPUT_NAME=sentinel2_composite.tif
INGESTION_INTERACTIVE_AUTH=false

PROCESSED_DATA_DIR=
PROCESSING_INPUT_NAME=sentinel2_composite.tif
PROCESSING_NDVI_NAME=ndvi.tif
PROCESSING_NDMI_NAME=ndmi.tif
PROCESSING_RED_BAND_INDEX=1
PROCESSING_NIR_BAND_INDEX=2
PROCESSING_SWIR_BAND_INDEX=3
PROCESSING_CLIP_MIN=-1.0
PROCESSING_CLIP_MAX=1.0

FEATURES_OUTPUT_CSV=features.csv
FEATURES_SOURCE_NAME=sentinel2
FEATURES_TIMESTAMP_UTC=
FEATURES_WRITE_TO_DB=true
FEATURES_SKIP_NODATA=true
FEATURES_GRID_PREFIX=cell

REGION_PIPELINE_ENABLED=true
REGION_PIPELINE_MIN_INTERVAL_SEC=300
