# Mapbox token for map layers
VITE_MAPBOX_TOKEN=pk.YOUR_MAPBOX_TOKEN_HERE

# Frontend API base path.
# If omitted, frontend uses:
# - development: VITE_BACKEND_URL (or http://localhost:8000)
# - production: /api
# Uncomment only if you want to force a specific path.
VITE_API_BASE_URL=/api

# Backend target for Vite dev proxy.
VITE_BACKEND_URL=http://localhost:8000
